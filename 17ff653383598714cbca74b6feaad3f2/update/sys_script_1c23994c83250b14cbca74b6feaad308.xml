        <script><![CDATA[(function executeRule(current, previous) {

    var facultyGR = new GlideRecord('x_2056113_smart_0_faculty');

    if (facultyGR.get(current.faculty)) {

        var requestedDays = parseInt(current.number_of_days);

        if (current.leave_type == 'Casual Leave') {

            if (requestedDays > facultyGR.casual_leave_balance) {

                gs.addErrorMessage(
                    'Insufficient Casual Leave Balance.'
                );

                current.status = 'Rejected';
                current.setAbortAction(true);
            }
        }

        if (current.leave_type == 'Sick Leave') {

            if (requestedDays > facultyGR.sick_leave_balance) {

                gs.addErrorMessage(
                    'Insufficient Sick Leave Balance.'
                );

                current.status = 'Rejected';
                current.setAbortAction(true);
				gs.addInfoMessage("Business Rule Executed");
            }
        }
    }

})(current, previous);]]></script>
